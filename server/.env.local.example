# Copy to .env.local and fill in values for local dev. Do NOT commit .env.local.
# Vercel Marketplace MongoDB integrations inject MONGODB_URI; we accept it here too.
MONGODB_URI=mongodb://localhost:27017
# V0.7+ template support: literal names like `happyword_dev` work as before.
# When the value contains `{pr}` it substitutes Vercel's
# `VERCEL_GIT_PULL_REQUEST_ID`; when it contains `{branch}` it substitutes a
# slugged `VERCEL_GIT_COMMIT_REF`. Used in production by Vercel's preview env
# (`MONGO_DB_NAME=happyword_pr_{pr}_e2e`) — local dev should keep the literal.
MONGO_DB_NAME=happyword_dev
JWT_SECRET=replace-with-openssl-rand-hex-32
JWT_EXPIRE_HOURS=24
ADMIN_BOOTSTRAP_USER=admin
ADMIN_BOOTSTRAP_PASS=replace-me
# Same value as Vercel CRON_SECRET if you call POST /api/v1/admin/cron/extract-pending locally.
CRON_SECRET=
# LLM provider for lesson image parsing: openai | qwen | doubao | kimi.
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL_TEXT=gpt-4o-mini
OPENAI_MODEL_VISION=gpt-4o
DASHSCOPE_API_KEY=
QWEN_MODEL_VISION=qwen3.6-plus
ARK_API_KEY=
DOUBAO_MODEL_VISION=doubao-seed-2-0-pro-260215
MOONSHOT_API_KEY=
# Optional compatibility alias accepted by Settings:
# KIMI_API_KEY=
KIMI_MODEL_VISION=kimi-k2.6
CORS_ALLOW_ORIGINS=*
LOG_LEVEL=info
# Parent Google OAuth (optional — hide button when unset)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Sign in with Apple (Services ID + Team ID + Key ID + .p8 PEM body)
APPLE_OAUTH_CLIENT_ID=
APPLE_OAUTH_TEAM_ID=
APPLE_OAUTH_KEY_ID=
# Paste the full .p8 private key including BEGIN/END lines (use \n in one line if needed).
APPLE_OAUTH_PRIVATE_KEY=
# WeChat website OAuth (optional — first-time users bind email by OTP)
WECHAT_OAUTH_APP_ID=
WECHAT_OAUTH_APP_SECRET=
# Alipay website OAuth (optional — first-time users bind email by OTP)
ALIPAY_OAUTH_APP_ID=
ALIPAY_OAUTH_APP_PRIVATE_KEY=
ALIPAY_OAUTH_PUBLIC_KEY=
OAUTH_CANONICAL_BASE_URL=https://happyword.cool
# Fixed Vercel Preview URL (register its /v1/oauth/{google,apple}/callback in each console).
OAUTH_PREVIEW_BASE_URL=https://happyword-zjumty-2580-terrymas-projects.vercel.app
OAUTH_HANDOFF_TTL_SECONDS=60
OAUTH_PENDING_BIND_TTL_SECONDS=600
OAUTH_LOCAL_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
