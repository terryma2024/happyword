{
  "version": 2,
  "ignoreCommand": "bash ./scripts/vercel_should_skip_build.sh",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/(.*)",     "destination": "/api/index.py" }
  ],
  "functions": {
    "api/index.py": {
      "runtime": "@vercel/python@6.38.0",
      "maxDuration": 60
    }
  }
}
