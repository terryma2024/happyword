# macOS
.DS_Store

# Vercel CLI link metadata (project link is local-only, never committed)
.vercel/

# Git worktrees (project-local isolated workspaces)
.worktrees/

# Gradle files (legacy / hybrid templates)
.gradle/
build/

# Local configuration file (sdk path, etc)
local.properties

# Log/OS Files
*.log

# Android Studio generated files and folders
captures/
.externalNativeBuild/
.cxx/
*.aab
*.apk
output-metadata.json

# IntelliJ
*.iml
.idea/
misc.xml
deploymentTargetDropDown.xml
render.experimental.xml

# Keystore files
*.jks
*.keystore

# Google Services (e.g. APIs or Firebase)
google-services.json

# Android Profiling
*.hprof

# HarmonyOS / OpenHarmony (DevEco Studio, hvigor, OhPM)
# Cache is `.hvigor/`; commit root `hvigor/` (hvigor-config.json5, etc.).
.hvigor/
oh_modules/
node_modules/
*.hap
*.hsp
*.har
.preview/
.vercel
